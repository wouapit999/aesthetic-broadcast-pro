# ── Database (serverless Postgres) ──────────────────────────
# Use a POOLED connection string (Neon pooler, Supabase :6543, or Vercel Postgres).
# Vercel Postgres / Neon example:
#   postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Seed admin (created by `npm run seed`)
ADMIN_EMAIL="admin@aesthetic.shop"
ADMIN_PASSWORD="ChangeMe123!"

# ── Public base URL (used to build the webhook callback URL) ─
# On Vercel this is provided automatically; set it for production if you use a custom domain.
NEXT_PUBLIC_BASE_URL=""

# ── Sending pipeline (Vercel Cron drains the queue) ─────────
# Max messages processed per cron dispatch (keep within function timeout).
SEND_BATCH_SIZE=50
SEND_MAX_ATTEMPTS=3
# Secret that protects the cron endpoint. Vercel Cron sends it automatically when set.
CRON_SECRET="change-me-cron-secret"

# ── WhatsApp Cloud API ──────────────────────────────────────
WHATSAPP_API_VERSION="v20.0"

# ── AI message generator (optional) ─────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ── Frontend (leave empty for same-origin) ──────────────────
NEXT_PUBLIC_API_URL=""
